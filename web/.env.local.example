NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Set to "true" to enable paid tiers on landing page + unlock Stripe checkout
NEXT_PUBLIC_PAYMENTS_LIVE=false

# Web Push VAPID public key (generate with: npx web-push generate-vapid-keys)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Stripe (set when enabling payments)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO_MONTHLY=price_...
# STRIPE_PRICE_ID_PRO_ANNUAL=price_...
