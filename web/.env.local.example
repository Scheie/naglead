# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_PRO_ANNUAL=price_...

# Feature flag — set to "true" to show pricing and enable checkout
NEXT_PUBLIC_PAYMENTS_LIVE=false

# Web Push VAPID public key (generate with: npx web-push generate-vapid-keys)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Upstash Redis (rate limiting — optional, all requests allowed if not set)
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Sentry (error tracking — optional, disabled if not set)
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ORG=your-org
# SENTRY_PROJECT=naglead
# SENTRY_AUTH_TOKEN=sntrys_...

# App Store URLs (shows "Coming Soon" if not set)
# NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/naglead/id...
# NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.naglead.app
